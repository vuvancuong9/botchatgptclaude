# Copy to .env.local and fill in. Never commit real keys.
# The orchestrator runs in deterministic MOCK mode when keys are absent,
# so typecheck/test/build all pass without any secret configured.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Native Anthropic Messages API (NOT the OpenAI-compat layer).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

# --- Auth (Phase 5: user API keys + RBAC) ------------------------------------
# Preferred auth: per-user API keys via the `x-ai-api-key` header. Bootstrap the
# first owner + key with:  npm run ai:create-owner
AI_OWNER_EMAIL=
AI_OWNER_NAME=
# Set to "1" to create an additional owner even if one exists.
AI_ORCHESTRATOR_FORCE_CREATE_OWNER=
# Optional pepper: when set, API keys are hashed with HMAC-SHA256 instead of
# plain SHA-256. Changing it invalidates all existing keys.
AI_ORCHESTRATOR_API_KEY_PEPPER=

# Legacy single admin key (migration window only). Used via `x-ai-admin-key`,
# and ONLY honored when AI_ORCHESTRATOR_ALLOW_LEGACY_ADMIN_KEY=1. Disable in
# production once every caller has a user API key.
AI_ORCHESTRATOR_ADMIN_KEY=
AI_ORCHESTRATOR_ALLOW_LEGACY_ADMIN_KEY=

# Persistence backend: "sqlite" (default, local/MVP) or "postgres" (production).
AI_ORCHESTRATOR_DB_PROVIDER=sqlite

# --- SQLite (local dev / MVP only) -------------------------------------------
# NOTE: SQLite is local/MVP only. On Vercel/serverless the filesystem is
# ephemeral; use Postgres/Supabase in production (see README "Production
# deployment").
AI_ORCHESTRATOR_DB=./.data/ai-orchestrator.db

# --- Postgres / Supabase (production, server-side only) ----------------------
# Required when AI_ORCHESTRATOR_DB_PROVIDER=postgres. The SERVICE ROLE key
# bypasses RLS and must NEVER be exposed to the browser / UI.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional direct Postgres connection string (reserved; Supabase client is the
# default transport).
# DATABASE_URL=

# Set to "1" to actually execute the TEST_RUNNER allowlisted commands.
# Default (unset) keeps test execution in a safe, non-spawning mock.
AI_ORCHESTRATOR_EXECUTE_TESTS=

# --- Rate limit --------------------------------------------------------------
# "memory" (default, local only) or "upstash" (production, multi-instance).
AI_ORCHESTRATOR_RATE_LIMIT_PROVIDER=memory
# Required when provider=upstash (missing env throws — no silent fallback).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Supabase smoke test (scripts/ai-orchestrator-smoke-supabase.ts) ---------
# Set to "1" to delete the smoke rows after the run (default: keep for audit).
AI_ORCHESTRATOR_SMOKE_CLEANUP=

# Set to "1" to emit internal (already-redacted) audit-failure warnings.
AI_ORCHESTRATOR_DEBUG=

# --- GitHub PR flow (Phase 6, server-side only) ------------------------------
# The token is used ONLY server-side for branch/file/PR writes. NEVER expose it
# to the browser and NEVER put it in NEXT_PUBLIC_*. Minimum scopes:
#   contents: write   (create branch, write files)
#   pull_requests: write (open the PR)
# The flow never merges, never pushes/forces the base branch, never deploys.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_DEFAULT_BRANCH=main

# Master switch for the create-PR route. When != "1" the route returns 403.
AI_ORCHESTRATOR_ENABLE_GITHUB_PR=0
# Dry-run is the SAFE DEFAULT (any value except "0"). Set to "0" for live PRs.
# Live mode additionally requires AI_ORCHESTRATOR_EXECUTE_TESTS=1.
AI_ORCHESTRATOR_PR_DRY_RUN=1

# Optional: require a recorded Supabase smoke pass before any live PR.
AI_ORCHESTRATOR_REQUIRE_SMOKE_PASS=
# ISO timestamp recorded after `npm run smoke:supabase` passes (e.g. 2026-06-04T10:00:00Z).
AI_ORCHESTRATOR_SUPABASE_SMOKE_PASSED_AT=

# --- Sandbox worker / execution plane (Phase 7) ------------------------------
# Control plane (this app) enqueues jobs; a SEPARATE worker process runs the
# allowlisted commands. Production must NOT run commands inline in a request.
#
# "database" (default): jobs persisted in the DB; run `npm run ai:worker`.
# "local": in-memory queue, dev/test only (forbidden in production).
AI_ORCHESTRATOR_WORKER_PROVIDER=database
# Inline command fallback for LOCAL DEV ONLY. Must be 0 in production.
AI_ORCHESTRATOR_ALLOW_INLINE_COMMANDS=0
# Worker tuning (used by `npm run ai:worker`).
AI_ORCHESTRATOR_WORKER_ID=worker-1
AI_ORCHESTRATOR_WORKER_CONCURRENCY=1
AI_ORCHESTRATOR_WORKER_POLL_INTERVAL_MS=3000
# Heartbeat / lease renewal (Phase 7.1.3). The worker renews its lease every
# HEARTBEAT_INTERVAL_MS so a long job (npm ci+typecheck+test+build can exceed
# 5 min) isn't re-claimed. The interval MUST be smaller than the lease (×1000).
AI_ORCHESTRATOR_WORKER_LEASE_SECONDS=300
AI_ORCHESTRATOR_WORKER_HEARTBEAT_INTERVAL_MS=60000
# Keep the job workspace after a run for debugging (default 0 = clean up).
AI_ORCHESTRATOR_WORKER_KEEP_WORKSPACE=0
# Base-drift hash guard (Phase 7.1.1). Default: ON in production, off in dev/test.
# Strict = a missing old_content_hash on modify/delete fails the job; and a live
# PR requires the worker to have verified base hashes (base_hash_checked=true).
AI_ORCHESTRATOR_PATCH_HASH_STRICT=1
# Atomic worker claim (Phase 7.1.2). On Postgres the claim uses the RPC
# claim_ai_worker_job (migration 008). Set to 1 ONLY after applying migration 008
# and `npm run smoke:worker-claim` passes — it clears the health warning and
# acknowledges it is safe to scale workers > 1.
AI_ORCHESTRATOR_WORKER_CLAIM_VERIFIED=0
# Lease renewal verified (Phase 7.1.3 / checked by the Phase 8 readiness gate).
# Set to 1 ONLY after `npm run smoke:worker-lease` passes. The readiness gate
# requires BOTH this and CLAIM_VERIFIED before scaling workers > 1.
AI_ORCHESTRATOR_WORKER_LEASE_VERIFIED=0

# --- Orchestrator TEST_RUNNER mode (Phase 7.2) -------------------------------
# How the orchestrator's TEST_RUNNER step executes:
#   "worker_async" : /run returns 202 immediately; resume after the job finishes.
#                    PRODUCTION DEFAULT — the request is never held open (Vercel).
#   "worker_wait"  : enqueue + wait (bounded) in the request. Debug only; can
#                    exceed the Vercel function timeout.
#   "inline"       : run in-process (dev/test only; blocked in production unless
#                    AI_ORCHESTRATOR_ALLOW_INLINE_COMMANDS=1).
# Default: worker_async in production, inline in dev/test. ("worker" = worker_wait alias.)
AI_ORCHESTRATOR_TEST_RUNNER_MODE=worker_async
# Bounded wait for worker_wait mode only.
AI_ORCHESTRATOR_TEST_JOB_TIMEOUT_MS=900000
AI_ORCHESTRATOR_TEST_JOB_POLL_MS=3000
# Optional: let the worker auto-resume finished async orchestrations. OFF by
# default — the scheduled cron resume is primary, and resume calls the model
# (review/judge) so the worker would need OpenAI/Anthropic keys. Shares the
# Phase 7.4 resume lock, so it never double-resumes with the cron.
AI_ORCHESTRATOR_WORKER_AUTO_RESUME=0

# --- Scheduled / cron resume (Phase 7.4) -------------------------------------
# In worker_async a finished run sits in waiting_for_worker until something
# resumes it. POST /api/ai-orchestrator/cron/resume drives this when no UI is
# open. It is FAIL-CLOSED: with no key the route is disabled (401), so it can
# never run unprotected.
#
# Shared cron secret. Send it as `x-ai-cron-key: <key>` (external scheduler) or
# `Authorization: Bearer <key>` (Vercel Cron — set the project's CRON_SECRET to
# this same value). NEVER expose it to the browser / NEXT_PUBLIC_*.
AI_ORCHESTRATOR_CRON_KEY=
# Max runs resumed per cron tick (clamped 1..50). Keep modest so one tick stays
# well under the function timeout.
AI_ORCHESTRATOR_RESUME_BATCH_SIZE=5
# Resume lock TTL in seconds (clamped 10..900). The lock stops two cron ticks
# from resuming the same orchestration.
AI_ORCHESTRATOR_RESUME_LOCK_TTL_SECONDS=120
# Opt-in (LESS SAFE): also accept `?cron_key=...` as a query token. Off by
# default — prefer a header; a query token can leak via logs / referrers.
AI_ORCHESTRATOR_ALLOW_CRON_QUERY_KEY=0
# Repo the worker checks out. REQUIRED in production (no local-copy fallback).
AI_ORCHESTRATOR_REPO_CLONE_URL=
# Optional read-only token for cloning a PRIVATE repo (used in the clone URL
# only, never logged, never passed to the test child process).
GITHUB_READ_TOKEN=
